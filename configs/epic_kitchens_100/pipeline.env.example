# Copy this file and adjust paths for your own machine.
# Do not put secrets in git.

# Local or single-machine workspace root.
BENCHMARK_ROOT=/path/to/video-benchmark

# EPIC-KITCHENS official downloader repo.
EPIC_DOWNLOADER_DIR=/path/to/video-benchmark/data/external/epic-kitchens-download-scripts-100

# Data root used by the downloader/transcoder/uploader.
DATA_ROOT=/path/to/video-benchmark/data

# Tencent COS config path. The file should contain [common] secret_id, secret_key, bucket, region.
COS_CONFIG=~/.cos.conf
COS_PREFIX=video-benchmark/epic-kitchens

# OpenAI-compatible VLM endpoint.
BASE_URL=http://127.0.0.1:8000/v1
MODEL=qwen35-a3b

# VLM video sampling parameters.
VLM_FPS=1
MAX_TOKENS=4096
